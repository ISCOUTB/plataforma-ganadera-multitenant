# Backend/.env.example — FarmLink
#
# Copia este archivo a .env y ajusta los valores según tu entorno.
# NUNCA versiones el archivo .env (ya está en .gitignore).
#
# Para desarrollo local con Docker (docker compose up db):
#   - DB_HOST=localhost
#   - DB_PORT=5433 (el docker-compose mapea 5433 del host al 5432 del contenedor)

# ---- Base de Datos (PostgreSQL) ----
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=farmlink

# ---- Servidor ----
PORT=3000

# ---- JWT ----
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-key-here
JWT_EXPIRES_IN=1d
# Refresh token usa un secreto DISTINTO para poder invalidar cada tipo independientemente
JWT_REFRESH_SECRET=your-refresh-secret-key-here
JWT_REFRESH_EXPIRES_IN=7d
